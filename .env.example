# Copy to .env and fill in. NEVER commit the real .env.

# --- Discord ---
# From https://discord.com/developers/applications/<APP_ID>/bot -> "Reset Token"
DISCORD_TOKEN=
# Your primary dev guild ID. Used for fast slash-command sync during development.
GUILD_ID=

# --- Database (matches docker-compose.yml; non-default 5433 to coexist with Linger) ---
DATABASE_URL=postgresql+asyncpg://vixen:vixen@localhost:5433/vixen

# --- Cache (non-default 6380 to coexist with Linger) ---
REDIS_URL=redis://localhost:6380/0

# --- Runtime ---
ENV=dev
LOG_LEVEL=INFO
