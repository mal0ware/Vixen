# Copy to .env and fill in. NEVER commit the real .env.

# --- Discord ---
# From https://discord.com/developers/applications/<APP_ID>/bot -> "Reset Token"
DISCORD_TOKEN=
# Your primary dev guild ID. Used for fast slash-command sync during development.
GUILD_ID=

# --- Database (matches docker-compose.yml defaults) ---
DATABASE_URL=postgresql+asyncpg://vixen:vixen@localhost:5432/vixen

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Runtime ---
ENV=dev
LOG_LEVEL=INFO
